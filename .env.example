# === 歌詞生成 LLM（DeepSeek 推奨） ===
# https://platform.deepseek.com で API キー取得
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# true=Thinking有効（遅い・token消費大） / false=歌詞生成向け（推奨）
DEEPSEEK_THINKING=false

# 汎用名（DEEPSEEK_* より優先したい場合）
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# === 韻候補プロバイダー（外部サイト API / スクレイピング） ===
RHYME_PROVIDERS=nwnwn,azrhymes,in-note
RHYME_USE_MOCK=false
RHYME_MAX_CANDIDATES=24
# true = 全ユーザーで古典韻（白々しきゃ等）をデフォルト表示。通常は Setup チェックで十分
# RHYME_ALLOW_ARCHAIC=false

# === 読み仮名（kuromoji） ===
# サーバー側で形態素解析。Vercel でも動作（初回リクエストは辞書ロードで数秒かかる場合あり）
# READING_USE_KUROMOJI=false で無効化（nwnwn API のみに戻す）

# === Supabase（保存機能用） ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
